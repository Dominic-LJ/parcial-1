Proceso Edades
	// maquina para determinar si eres mayor de edad
	Definir edad Como Entero;
	Escribir 'ingresa tus ańos';
	Leer edad;
	si edad > 10 Entonces
		Escribir "eres mayor";
		

		
	FinSi
	Si edad = 10 Entonces
		Escribir "tienes 10";
	FinSi
	si edad < 10 Entonces
		Escribir  "eres menor";
	FinSi
	
FinProceso
